# INSTALL
apt update
apt install openvpn easy-rsa openssl apache2 -y

# =========================
# BUAT FOLDER CERTIFICATE
# =========================

mkdir -p /home/cert/Cert.web

cd /home/cert/Cert.web

# =========================
# BUAT PRIVATE KEY CA
# =========================

openssl genrsa -des3 -out MyCA.key 2048

# =========================
# BUAT CERTIFICATE CA
# =========================

openssl req -x509 -new -nodes \
-key MyCA.key \
-sha256 -days 365 \
-out MyCA.pem

# =========================
# CONVERT KE P7B
# =========================

openssl crl2pkcs7 -nocrl \
-certfile MyCA.pem \
-out MyCA.p7b

# =========================
# BUAT KEY WEBSITE
# =========================

openssl genrsa -out www.key 2048

# =========================
# BUAT CSR WEBSITE
# =========================

openssl req -new \
-key www.key \
-out www.csr

# Common Name isi:
# www.kaltaramaju.com

# =========================
# BUAT CONFIG EXTENSION SSL
# =========================

nano config.txt

authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage=digitalSignature,nonRepudiation,keyEncipherment,dataEncipherment
subjectAltName=@alt_names

[alt_names]
DNS.1=www.kaltaramaju.com
DNS.2=kaltaramaju.com
IP.1=192.168.12.1

# =========================
# SIGN CERTIFICATE WEBSITE
# =========================

openssl x509 -req \
-in www.csr \
-CA MyCA.pem \
-CAkey MyCA.key \
-CAcreateserial \
-out www.crt \
-days 365 \
-sha256 \
-extfile config.txt

# =========================
# CONVERT CERTIFICATE
# =========================

openssl pkcs7 \
-in MyCA.p7b \
-print_certs \
-out MyCA.cer

# =========================
# TAMBAHKAN KE TRUSTED CA DEBIAN
# =========================

cp MyCA.cer /usr/local/share/ca-certificates/

update-ca-certificates

a2enmod ssl

cp /etc/apache2/sites-available/default-ssl.conf \
/etc/apache2/sites-available/db.Web-Daviid-ssl.conf

/usr/sbin/a2enmod ssl

cp /etc/apache2/sites-available/default-ssl.conf \
/etc/apache2/sites-available/db.Web-Daviid-ssl.conf

nano /etc/apache2/sites-available/db.Web-Daviid-ssl.conf

<VirtualHost *:443>

    ServerName www.kaltaramaju.com

    DocumentRoot /var/www/html

    SSLEngine on

    SSLCertificateFile /home/cert/Cert.web/www.crt
    SSLCertificateKeyFile /home/cert/Cert.web/www.key
    SSLCACertificateFile /home/cert/Cert.web/MyCA.pem

</VirtualHost>

/usr/sbin/a2ensite db.Web-Daviid-ssl.conf

systemctl restart apache2

